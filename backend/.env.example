# NEXUS — Backend Configuration
# Copy this file to .env and fill in your values

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Keys (Get these from Google AI Studio and Tavily Console)
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Databases
DATABASE_URL=postgresql://neondb_owner:...@ep-round-dew...aws.neon.tech/neondb?sslmode=require
REDIS_URL=redis://default:...@redis-10439.crce309...ec2.cloud.redislabs.com:10439

# Security (Generate a secure key using `openssl rand -hex 32`)
JWT_SECRET_KEY=generate_a_secure_hex_key_here_for_development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe Configurations
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
