# NEXUS — Backend Configuration
# Copy this file to .env and fill in your values

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Keys (Get these from Azure OpenAI and Tavily Console)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-01
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Databases
DATABASE_URL=postgresql://your_db_user:your_db_password@your_azure_db_host:5432/your_db_name?sslmode=require
REDIS_URL=redis://localhost:6379/0

# Security (Generate a secure key using `openssl rand -hex 32`)
JWT_SECRET_KEY=generate_a_secure_hex_key_here_for_development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe Configurations
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
